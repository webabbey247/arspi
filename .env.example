# ─────────────────────────────────────────────────────────────────────────────
# Environment variable reference for ARSPI
#
# On shared hosting (cPanel Node.js App):
#   Set these in cPanel → Node.js App → your app → Environment Variables tab.
#   Do NOT place a .env file on the server — Passenger does not load it.
#
# In GitHub Actions:
#   Add DATABASE_URL, NEXTAUTH_URL, NEXTAUTH_SECRET, NEXT_PUBLIC_APP_URL
#   under Settings → Secrets and variables → Actions (needed at build time).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# ── NextAuth ─────────────────────────────────────────────────────────────────
# NEXTAUTH_URL must be the exact URL users visit (no trailing slash)
NEXTAUTH_URL=https://yourdomain.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-secret

# ── App URL (used in Stripe redirects and password-reset links) ──────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=ARPS Institute <noreply@yourdomain.com>

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── UploadThing ───────────────────────────────────────────────────────────────
# Found in the UploadThing dashboard under API Keys
UPLOADTHING_TOKEN=...

# ── Node.js ───────────────────────────────────────────────────────────────────
NODE_ENV=production
